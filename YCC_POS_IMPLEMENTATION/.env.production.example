# YCC POS Production Environment Variables
# Copy this file to .env.production and update with your actual values

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
DATABASE_URL="postgresql://yccpos_user:yccpos_secure_password_2024@localhost:5432/ycc_pos"
DATABASE_HOST="localhost"
DATABASE_PORT="5432"
DATABASE_NAME="ycc_pos"
DATABASE_USER="yccpos_user"
DATABASE_PASSWORD="yccpos_secure_password_2024"

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD="yccpos_redis_password_2024"

# ===========================================
# JWT CONFIGURATION
# ===========================================
# IMPORTANT: Change these secrets in production!
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV="production"
PORT="3001"
HOST="0.0.0.0"

# ===========================================
# CORS CONFIGURATION
# ===========================================
CORS_ORIGIN="https://pos.yccpos.com,https://kds.yccpos.com,https://admin.yccpos.com"
CORS_CREDENTIALS="true"

# ===========================================
# SSL CONFIGURATION
# ===========================================
SSL_CERT_PATH="/etc/letsencrypt/live/pos.yccpos.com/fullchain.pem"
SSL_KEY_PATH="/etc/letsencrypt/live/pos.yccpos.com/privkey.pem"

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL="info"
LOG_FILE="/var/www/ycc-pos/logs/api-combined.log"
ERROR_LOG_FILE="/var/www/ycc-pos/logs/api-error.log"
OUT_LOG_FILE="/var/www/ycc-pos/logs/api-out.log"

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# ===========================================
# FILE UPLOAD CONFIGURATION
# ===========================================
UPLOAD_MAX_SIZE="10485760"
UPLOAD_ALLOWED_TYPES="image/jpeg,image/png,image/gif,application/pdf"

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@pos.yccpos.com"
SMTP_PASS="your-smtp-password"
FROM_EMAIL="noreply@pos.yccpos.com"
FROM_NAME="YCC POS"

# ===========================================
# PAYMENT PROCESSING
# ===========================================
STRIPE_PUBLIC_KEY="pk_live_your_stripe_public_key"
STRIPE_SECRET_KEY="sk_live_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# ===========================================
# EXTERNAL APIS
# ===========================================
WEATHER_API_KEY="your-weather-api-key"
MAPS_API_KEY="your-maps-api-key"

# ===========================================
# MONITORING
# ===========================================
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"
NEW_RELIC_LICENSE_KEY="your-newrelic-license-key"

# ===========================================
# BACKUP CONFIGURATION
# ===========================================
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS="30"
BACKUP_S3_BUCKET="ycc-pos-backups"
BACKUP_S3_REGION="us-east-1"
BACKUP_S3_ACCESS_KEY="your-s3-access-key"
BACKUP_S3_SECRET_KEY="your-s3-secret-key"

# ===========================================
# SECURITY
# ===========================================
BCRYPT_ROUNDS="12"
SESSION_SECRET="your-session-secret-min-32-chars"
COOKIE_SECRET="your-cookie-secret-min-32-chars"

# ===========================================
# PERFORMANCE
# ===========================================
CLUSTER_WORKERS="max"
MAX_MEMORY_RESTART="1G"
MIN_UPTIME="10s"
MAX_RESTARTS="10"

# ===========================================
# DEVELOPMENT (DO NOT USE IN PRODUCTION)
# ===========================================
# DEBUG="ycc-pos:*"
# ENABLE_HTTP_LOGGING="true"
# ENABLE_QUERY_LOGGING="true"

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_ANALYTICS="true"
ENABLE_ERROR_REPORTING="true"
ENABLE_PERFORMANCE_MONITORING="true"
ENABLE_AUDIT_LOGGING="true"

# ===========================================
# BUSINESS CONFIGURATION
# ===========================================
BUSINESS_NAME="YCC Country Club"
BUSINESS_ADDRESS="123 Club Lane, City, State 12345"
BUSINESS_PHONE="(555) 123-4567"
BUSINESS_EMAIL="info@pos.yccpos.com"
BUSINESS_WEBSITE="https://pos.yccpos.com"
CURRENCY="USD"
TIMEZONE="America/New_York"
LOCALE="en-US"

# ===========================================
# INTEGRATION CONFIGURATION
# ===========================================
KITCHEN_DISPLAY_WEBHOOK_URL="https://kds.yccpos.com/webhooks/orders"
ACCOUNTING_WEBHOOK_URL="https://accounting.yccpos.com/webhooks/transactions"
INVENTORY_WEBHOOK_URL="https://inventory.yccpos.com/webhooks/updates"

# ===========================================
# COMPLIANCE
# ===========================================
DATA_RETENTION_DAYS="2555"  # 7 years
GDPR_COMPLIANCE="true"
CCPA_COMPLIANCE="true"
PCI_COMPLIANCE="true"
