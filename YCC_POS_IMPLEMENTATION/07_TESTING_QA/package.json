{
  "name": "@ycc/testing",
  "version": "1.0.0",
  "description": "Testing y QA para YCC POS",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "test": "jest",
    "test:unit": "jest --testPathPattern=unit-tests",
    "test:integration": "jest --testPathPattern=integration-tests",
    "test:e2e": "playwright test",
    "test:performance": "playwright test --config=playwright.performance.config.js",
    "test:accessibility": "playwright test --config=playwright.accessibility.config.js",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "quality": "sonar-scanner",
    "coverage:report": "jest --coverage --coverageReporters=text-lcov | coveralls",
    "performance:audit": "lighthouse http://localhost:3000 --output=reports/performance",
    "accessibility:audit": "pa11y http://localhost:3000 --reporter=html --output=reports/accessibility"
  },
  "dependencies": {
    "@testing-library/react": "^13.4.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/user-event": "^14.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.40.0",
    "msw": "^2.0.0",
    "axe-core": "^4.8.0",
    "pa11y": "^7.0.0",
    "lighthouse": "^11.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-react": "^7.33.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-testing-library": "^6.2.0",
    "prettier": "^3.1.0",
    "sonar-scanner": "^3.3.0",
    "typescript": "^5.3.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/tools/test-setup.js"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/../$1/src"
    },
    "collectCoverageFrom": [
      "../**/*.{ts,tsx}",
      "!../**/dist/**",
      "!../**/node_modules/**",
      "!../**/coverage/**"
    ],
    "coverageDirectory": "reports/coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageThresholds": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "playwright": {
    "testDir": "e2e-tests",
    "fullyParallel": true,
    "workers": 4,
    "reporter": [
      ["html"],
      ["json"],
      ["junit"]
    ],
    "use": {
      "actions": false,
      "trace": "on"
    },
    "webServer": {
      "command": "pnpm start",
      "port": 3000,
      "reuseExistingServer": !process.env.CI
    }
  }
}
