# ======================================
# YCC POS - Production Environment
# ======================================
# IMPORTANTE: No commitear este archivo con valores reales
# Copiar a .env.production.local para desarrollo local
# Configurar en Vercel Dashboard → Environment Variables para producción

# ======================================
# API Gateway Configuration (03_API_GATEWAY)
# ======================================

# Base de datos PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/ycc_pos?schema=public"

# JWT Secret (mínimo 32 caracteres)
JWT_SECRET="tu-jwt-secret-super-seguro-cambiar-en-produccion"

# Puerto del servidor (Vercel ignora esto, usa el puerto asignado)
PORT=3004

# Entorno
NODE_ENV=production

# Origenes permitidos para CORS (cambiar en producción)
# En producción, especifica tu dominio exacto:
# CORS_ORIGIN="https://tu-dominio.vercel.app"
CORS_ORIGIN="*"

# ======================================
# Frontend Applications
# ======================================

# URL del API para las aplicaciones frontend
# Cambiar por tu URL de Vercel después del despliegue
VITE_API_URL="https://tu-dominio.vercel.app/api"
VITE_WS_URL="wss://tu-dominio.vercel.app"

# ======================================
# KDS System (05_KDS_SYSTEM)
# ======================================
VITE_KDS_API_URL="https://tu-dominio.vercel.app/api"

# ======================================
# Admin Panel (06_ADMIN_PANEL)
# ======================================
VITE_ADMIN_API_URL="https://tu-dominio.vercel.app/api"
