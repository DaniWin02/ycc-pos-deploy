// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// USUARIOS Y AUTENTICACIÓN
// ========================================

model User {
  id                    String              @id @default(cuid())
  username              String              @unique
  email                 String              @unique
  passwordHash          String
  firstName             String
  lastName              String
  role                  UserRole            @default(CASHIER)
  permissions           Json?               // Permisos específicos del usuario
  phone                 String?
  avatar                String?
  isActive              Boolean             @default(true)
  lastLogin             DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  cashSessionsOpened    CashSession[]       @relation("CashSessionOpenedBy")
  cashSessionsClosed    CashSession[]       @relation("CashSessionClosedBy")
  shifts                Shift[]
  cashMovements         CashMovement[]
  inventoryMovements    InventoryMovement[]
  orders                Order[]
  comandasAsignadas     Comanda[]           @relation("ComandaAsignada")
}

// ========================================
// TIENDAS Y TERMINALES
// ========================================

model Store {
  id          String     @id @default(cuid())
  name        String
  address     String
  phone       String
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  terminals   Terminal[]
  orders      Order[]
}

model Terminal {
  id                 String              @id @default(cuid())
  storeId            String
  name               String
  location           String
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  store              Store               @relation(fields: [storeId], references: [id])
  cashSessions       CashSession[]
  inventoryMovements InventoryMovement[]
  orders             Order[]
}

// ========================================
// SESIONES DE CAJA
// ========================================

model CashSession {
  id                  String            @id @default(cuid())
  terminalId          String
  openedByUserId      String
  closedByUserId      String?
  shiftId             String?           // Relación con turno
  openingFloat        Decimal
  closingFloat        Decimal?
  expectedFloat       Decimal?          // Monto esperado calculado
  countedCash         Decimal?          // Efectivo contado manualmente
  difference          Decimal?          // Diferencia entre esperado y contado
  totalSales          Decimal?          // Total de ventas
  totalCash           Decimal?          // Total en efectivo
  totalCard           Decimal?          // Total en tarjeta
  totalMemberAccount  Decimal?          // Total en cuenta de socio
  transactionCount    Int?              // Número de transacciones
  notes               String?           // Notas del corte
  status              CashSessionStatus @default(OPEN)
  openedAt            DateTime          @default(now())
  closedAt            DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  terminal            Terminal          @relation(fields: [terminalId], references: [id])
  openedByUser        User              @relation("CashSessionOpenedBy", fields: [openedByUserId], references: [id])
  closedByUser        User?             @relation("CashSessionClosedBy", fields: [closedByUserId], references: [id])
  shift               Shift?            @relation(fields: [shiftId], references: [id])
  cashMovements       CashMovement[]
}

// ========================================
// TURNOS DE CAJEROS
// ========================================

model Shift {
  id              String        @id @default(cuid())
  userId          String
  terminalId      String
  status          ShiftStatus   @default(ACTIVE)
  startedAt       DateTime      @default(now())
  endedAt         DateTime?
  totalSales      Decimal?
  transactionCount Int?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
  cashSessions    CashSession[]
  cashMovements   CashMovement[]
}

// ========================================
// MOVIMIENTOS DE CAJA
// ========================================

model CashMovement {
  id              String             @id @default(cuid())
  cashSessionId   String?
  shiftId         String?
  userId          String
  type            CashMovementType
  amount          Decimal
  paymentMethod   PaymentMethod?
  reference       String?            // Referencia a orden, retiro, etc.
  description     String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  cashSession     CashSession?       @relation(fields: [cashSessionId], references: [id])
  shift           Shift?             @relation(fields: [shiftId], references: [id])
  user            User               @relation(fields: [userId], references: [id])
}

// ========================================
// CLIENTES/SOCIOS
// ========================================

model Customer {
  id           String   @id @default(cuid())
  memberNumber String?  @unique
  firstName    String
  lastName     String
  email        String?
  phone        String?
  address      String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

// ========================================
// ESTACIONES DE COCINA (KDS)
// ========================================

model Station {
  id          String    @id @default(cuid())
  name        String    @unique
  displayName String    // Nombre para mostrar
  color       String?   // Color hex para UI
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

// ========================================
// PRODUCTOS Y CATEGORÍAS
// ========================================

model Category {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  parentId    String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryChildren")
  products    Product[]
}

model Product {
  id                 String              @id @default(cuid())
  sku                String              @unique
  name               String
  description        String?
  categoryId         String
  stationId          String              // Estación de cocina asignada (OBLIGATORIO)
  price              Decimal
  cost               Decimal?
  taxRate            Decimal             @default(0.16)
  trackInventory     Boolean             @default(true)
  currentStock       Decimal             @default(0)
  minStockLevel      Decimal?
  maxStockLevel      Decimal?
  reorderPoint       Decimal?
  unit               String              @default("unidad")
  image              String?
  preparationTime    Int?                // Tiempo de preparación en minutos
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  category           Category            @relation(fields: [categoryId], references: [id])
  station            Station             @relation(fields: [stationId], references: [id])
  inventoryMovements InventoryMovement[]
  recipe             Recipe?
  stockAlerts        StockAlert[]
}

// ========================================
// INVENTARIO
// ========================================

model Ingredient {
  id                 String              @id @default(cuid())
  name               String              @unique
  description        String?
  unit               String
  currentStock       Decimal             @default(0)
  minStockLevel      Decimal?
  currentCost        Decimal
  supplierId         String?
  expirationDate     DateTime?
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  inventoryMovements InventoryMovement[]
  recipeIngredients  RecipeIngredient[]
}

model InventoryMovement {
  id           String       @id @default(cuid())
  productId    String
  ingredientId String?
  type         MovementType
  quantity     Decimal
  unitCost     Decimal?
  reason       String?
  reference    String?
  storeId      String
  terminalId   String?
  createdById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  product      Product      @relation(fields: [productId], references: [id])
  ingredient   Ingredient?  @relation(fields: [ingredientId], references: [id])
  terminal     Terminal?    @relation(fields: [terminalId], references: [id])
  createdBy    User         @relation(fields: [createdById], references: [id])
}

// ========================================
// ÓRDENES Y VENTAS
// ========================================

model Order {
  id              String        @id @default(cuid())
  folio           String        @unique
  customerId      String?
  customerName    String?
  tableId         String?
  terminalId      String
  storeId         String
  createdByUserId String
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal
  taxAmount       Decimal       @default(0)
  discountAmount  Decimal       @default(0)
  tipAmount       Decimal       @default(0)
  totalAmount     Decimal
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  terminal        Terminal      @relation(fields: [terminalId], references: [id])
  store           Store         @relation(fields: [storeId], references: [id])
  createdBy       User          @relation(fields: [createdByUserId], references: [id])
  items           OrderItem[]
  payments        Payment[]
}

model OrderItem {
  id             String          @id @default(cuid())
  orderId        String
  productId      String
  productName    String
  sku            String
  stationId      String?         // Estación asignada al item (para filtrado en KDS)
  quantity       Decimal
  unitPrice      Decimal
  totalPrice     Decimal
  taxRate        Decimal         @default(0.16)
  taxAmount      Decimal
  discountAmount Decimal         @default(0)
  modifiers      Json
  notes          String?
  status         OrderItemStatus @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  order          Order           @relation(fields: [orderId], references: [id])
}

model Payment {
  id                String        @id @default(cuid())
  orderId           String
  method            PaymentMethod
  amount            Decimal
  reference         String?
  authorizationCode String?
  status            PaymentStatus @default(PENDING)
  capturedAt        DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  order             Order         @relation(fields: [orderId], references: [id])
}

// ========================================
// MODIFICADORES
// ========================================

model ModifierGroup {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  isRequired  Boolean    @default(false)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  modifiers   Modifier[]
}

model Modifier {
  id              String        @id @default(cuid())
  modifierGroupId String
  name            String
  description     String?
  priceAdd        Decimal       @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id])
}

// ========================================
// ENUMS DEL SISTEMA
// ========================================

enum OrderStatus {
  PENDING      // Orden recibida, esperando preparación
  PREPARING    // En preparación en cocina
  READY        // Lista para entregar
  DELIVERED    // Entregada al cliente (historial)
  CANCELLED    // Cancelada
  REFUNDED     // Reembolsada
}

enum OrderItemStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  CAPTURED
  VOIDED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  MEMBER_ACCOUNT
  MIXED
}

enum UserRole {
  ADMIN
  CASHIER
  MANAGER
  KITCHEN
  WAITER
  DELIVERY
  CHEF
  SUPERVISOR
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

enum ShiftStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum CashMovementType {
  SALE
  OPENING
  CLOSING
  WITHDRAWAL
  DEPOSIT
  ADJUSTMENT
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

// ========================================
// COMANDAS Y GESTIÓN DE COCINA
// ========================================

model Comanda {
  id              String        @id @default(cuid())
  folio           String        @unique
  cliente         String
  mesa            String?
  domicilio       String?
  telefono        String?
  tipo            ComandaTipo   @default(MESA)
  estado          ComandaEstado @default(PENDIENTE)
  prioridad       Prioridad     @default(MEDIA)
  items           ComandaItem[]
  total           Decimal       @db.Decimal(10, 2)
  notas           String?
  mesero          String?
  delivery        String?
  asignadoAUserId String?       // Usuario asignado para entrega
  asignadoA       User?         @relation("ComandaAsignada", fields: [asignadoAUserId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  completedAt     DateTime?
  estimatedTime   Int?          // Tiempo estimado en minutos
}

model ComandaItem {
  id        String      @id @default(cuid())
  productId String?     // ID del producto para tracking
  nombre    String
  cantidad  Int
  precio    Decimal     @db.Decimal(10, 2)
  notas     String?
  estado    ItemEstado  @default(PENDIENTE)
  image     String?
  station   String?     // Estación de cocina asignada
  comandaId String
  comanda   Comanda     @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  preparadoPor String?   // Usuario que marcó como listo
  recogidoPor  String?   // Usuario que recogió el pedido
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  readyAt   DateTime?   // Cuando se marcó como listo
  pickedAt  DateTime?   // Cuando se recogió
}

// ========================================
// ENUMS PARA COMANDAS
// ========================================

enum ComandaTipo {
  MESA
  DOMICILIO
  LLEVAR
}

enum ComandaEstado {
  PENDIENTE
  PREPARANDO
  LISTO
  ENTREGANDO
  ENTREGADO
  CANCELADO
}

enum ItemEstado {
  PENDIENTE
  PREPARANDO
  LISTO
  RECOGIDO
  ENTREGADO
}

enum Prioridad {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

// ========================================
// SISTEMA DE RECETAS
// ========================================

model Recipe {
  id                String             @id @default(cuid())
  productId         String             @unique
  name              String
  description       String?
  instructions      String?
  preparationTime   Int?               // Minutos
  servings          Int                @default(1)
  costPerServing    Decimal?
  isActive          Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  product           Product            @relation(fields: [productId], references: [id])
  ingredients       RecipeIngredient[]
}

model RecipeIngredient {
  id           String     @id @default(cuid())
  recipeId     String
  ingredientId String
  quantity     Decimal
  unit         String
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  recipe       Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
}

// ========================================
// SISTEMA DE ALERTAS DE INVENTARIO
// ========================================

model StockAlert {
  id          String           @id @default(cuid())
  productId   String
  type        StockAlertType
  level       Decimal
  message     String
  isResolved  Boolean          @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  product     Product          @relation(fields: [productId], references: [id])
}

enum StockAlertType {
  LOW_STOCK
  OUT_OF_STOCK
  REORDER_POINT
  EXPIRING_SOON
}

// ========================================
// ESTACIONES DE COCINA
// ========================================

model KitchenStation {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========================================
// PROVEEDORES (SUPPLIERS)
// ========================================

model Supplier {
  id              String          @id @default(cuid())
  name            String          @unique
  description     String?
  contactPerson   String?
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  country         String?
  postalCode      String?
  taxId           String?
  paymentTerms    String?
  deliveryDays    Json?           // Array de días de entrega
  minimumOrder    Decimal?
  isActive        Boolean         @default(true)
  rating          Decimal?        @default(0)
  totalOrders     Int             @default(0)
  lastOrderDate   DateTime?
  notes           String?
  website         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  purchaseOrders  PurchaseOrder[]
}

// ========================================
// ÓRDENES DE COMPRA (PURCHASE ORDERS)
// ========================================

model PurchaseOrder {
  id                   String              @id @default(cuid())
  orderNumber          String              @unique
  supplierId           String
  storeId              String
  status               PurchaseOrderStatus @default(DRAFT)
  orderDate            DateTime            @default(now())
  expectedDeliveryDate DateTime
  actualDeliveryDate   DateTime?
  subtotal             Decimal
  taxAmount            Decimal
  totalAmount          Decimal
  notes                String?
  internalNotes        String?
  createdBy            String
  approvedBy           String?
  receivedBy           String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  supplier             Supplier            @relation(fields: [supplierId], references: [id])
  items                PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id                String        @id @default(cuid())
  purchaseOrderId   String
  ingredientId      String
  quantity          Decimal
  unit              String
  unitPrice         Decimal
  totalPrice        Decimal
  receivedQuantity  Decimal       @default(0)
  remainingQuantity Decimal
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  SENT
  PARTIAL_RECEIVED
  RECEIVED
  CANCELLED
}

// ========================================
// CONTEOS FÍSICOS (PHYSICAL COUNTS)
// ========================================

model PhysicalCount {
  id                 String             @id @default(cuid())
  countNumber        String             @unique
  storeId            String
  status             PhysicalCountStatus @default(DRAFT)
  countDate          DateTime
  startedAt          DateTime?
  completedAt        DateTime?
  countedBy          String?
  reviewedBy         String?
  notes              String?
  varianceAmount     Decimal            @default(0)
  variancePercentage Decimal            @default(0)
  totalItems         Int                @default(0)
  countedItems       Int                @default(0)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  items              PhysicalCountItem[]
}

model PhysicalCountItem {
  id                String        @id @default(cuid())
  physicalCountId   String
  ingredientId      String
  expectedQuantity  Decimal
  countedQuantity   Decimal?
  varianceQuantity  Decimal?
  varianceValue     Decimal?
  unit              String
  unitCost          Decimal
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  physicalCount     PhysicalCount @relation(fields: [physicalCountId], references: [id], onDelete: Cascade)
}

enum PhysicalCountStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  REVIEWED
  CANCELLED
}

// ========================================
// REGISTRO DE DESPERDICIO (WASTE)
// ========================================

model WasteRecord {
  id           String         @id @default(cuid())
  wasteNumber  String         @unique
  storeId      String
  wasteDate    DateTime       @default(now())
  reportedBy   String
  approvedBy   String?
  status       WasteStatus    @default(PENDING)
  totalValue   Decimal        @default(0)
  reason       String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  items        WasteItem[]
}

model WasteItem {
  id            String      @id @default(cuid())
  wasteRecordId String
  ingredientId  String
  quantity      Decimal
  unit          String
  unitCost      Decimal
  totalCost     Decimal
  reason        WasteReason
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  wasteRecord   WasteRecord @relation(fields: [wasteRecordId], references: [id], onDelete: Cascade)
}

enum WasteStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WasteReason {
  EXPIRED
  DAMAGED
  SPOILED
  OVERPRODUCTION
  CONTAMINATED
  OTHER
}
